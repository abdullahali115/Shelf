<com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="40dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="@color/secondary"
    android:background="@color/primary"
    android:layout_marginHorizontal="20dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        >


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bookCover"
            android:layout_width="180dp"
            android:layout_height="270dp"
            app:cardCornerRadius="24dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/secondary"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="32dp"
            >

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:id="@+id/bookTitle"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lorem Ipsum"
                    android:gravity="center|top"
                    android:layout_marginTop="60dp"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:fontFamily="casual"
                    />

                <TextView
                    android:id="@+id/bookISBN"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@+id/bookAuthor"
                    android:layout_marginTop="4dp"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:text="ISBN: 123456"
                    android:gravity="center"
                    android:textSize="14sp"
                    />
                <TextView
                    android:id="@+id/bookAuthor"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/bookPubYear"
                    android:layout_marginTop="4dp"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:text="Author: Lorem"
                    android:gravity="center"
                    android:textSize="14sp"
                    />
                <TextView
                    android:id="@+id/bookPubYear"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginTop="4dp"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:text="Publication Year: 1234"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:paddingBottom="15dp"
                    />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <Space
            app:layout_constraintTop_toBottomOf="@id/bookCover"
            android:layout_width="match_parent"
            android:layout_height="32dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>