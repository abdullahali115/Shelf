<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".signup_fragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        >
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/emailCard"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="@color/primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            >
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                >

                <ImageView
                    android:id="@+id/email_ic"
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:src="@drawable/ic_email"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    />
                <TextView
                    android:id="@+id/emailHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="Email Address"
                    android:textSize="10sp"
                    app:layout_constraintStart_toEndOf="@id/email_ic"
                    app:layout_constraintTop_toTopOf="@id/email_ic"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="15dp"
                    />
                <EditText
                    android:id="@+id/emailText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="15dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginTop="2dp"
                    android:scrollHorizontally="true"
                    android:inputType="textEmailAddress"
                    android:textSize="20sp"
                    app:layout_constraintTop_toBottomOf="@id/emailHeader"
                    app:layout_constraintStart_toEndOf="@id/email_ic"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:background="@android:color/transparent"
                    />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/passwordCard"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="@color/primary"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/emailCard"
            >
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                >

                <ImageView
                    android:id="@+id/password_ic"
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:src="@drawable/ic_email"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    />
                <TextView
                    android:id="@+id/passwordHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="Password"
                    android:textSize="10sp"
                    app:layout_constraintStart_toEndOf="@id/password_ic"
                    app:layout_constraintTop_toTopOf="@id/password_ic"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="15dp"
                    />
                <EditText
                    android:id="@+id/passwordText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="15dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="20dp"
                    android:scrollHorizontally="true"
                    android:inputType="textPassword"
                    android:textSize="20sp"
                    app:layout_constraintTop_toBottomOf="@id/passwordHeader"
                    app:layout_constraintStart_toEndOf="@id/password_ic"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:background="@android:color/transparent"
                    />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/userNdob"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/passwordCard"
            >
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/usernameCard"
                android:layout_width="0dp"
                android:layout_weight="1.3"
                android:layout_height="60dp"
                app:cardCornerRadius="30dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/primary"
                app:layout_constraintTop_toBottomOf="@id/passwordCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                >
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    >
                    <ImageView
                        android:id="@+id/user_ic"
                        android:layout_width="20dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:src="@drawable/ic_email"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        />
                    <TextView
                        android:id="@+id/userHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:hint="Username"
                        android:textSize="10sp"
                        app:layout_constraintStart_toEndOf="@id/user_ic"
                        app:layout_constraintTop_toTopOf="@id/user_ic"
                        android:layout_marginTop="10dp"
                        android:layout_marginStart="15dp"
                        />
                    <EditText
                        android:id="@+id/userText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="15dp"
                        android:layout_marginEnd="20dp"
                        android:layout_marginTop="2dp"
                        android:scrollHorizontally="true"
                        android:inputType="text"
                        android:textSize="20sp"
                        app:layout_constraintTop_toBottomOf="@id/userHeader"
                        app:layout_constraintStart_toEndOf="@id/user_ic"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:background="@android:color/transparent"
                        />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
            <Space
                android:layout_width="5dp"
                android:layout_height="match_parent"/>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/dobCard"
                android:layout_width="0dp"
                android:layout_weight="1.2"
                android:layout_height="60dp"
                app:cardCornerRadius="30dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/primary"
                >
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    >
                    <ImageView
                        android:id="@+id/dob_ic"
                        android:layout_width="20dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:src="@drawable/ic_email"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        />
                    <TextView
                        android:id="@+id/dobHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:hint="DOB"
                        android:textSize="10sp"
                        app:layout_constraintStart_toEndOf="@id/dob_ic"
                        app:layout_constraintTop_toTopOf="@id/dob_ic"
                        android:layout_marginTop="10dp"
                        android:layout_marginStart="15dp"
                        />
                    <EditText
                        android:id="@+id/dobText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="15dp"
                        android:layout_marginEnd="20dp"
                        android:layout_marginTop="2dp"
                        android:scrollHorizontally="true"
                        android:inputType="text"
                        android:textSize="20sp"
                        app:layout_constraintTop_toBottomOf="@id/dobHeader"
                        app:layout_constraintStart_toEndOf="@id/dob_ic"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:background="@android:color/transparent"
                        />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sign up"
            android:textColor="@color/textSecondary"
            android:textSize="14sp"
            android:paddingVertical="13dp"
            android:paddingHorizontal="35dp"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@+id/userNdob"
            android:backgroundTint="@color/textPrimary"
            app:rippleColor="@android:color/darker_gray"
            app:strokeWidth="2dp"
            app:strokeColor="@color/black"
            />

        <LinearLayout
            android:id="@+id/extraOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintTop_toBottomOf="@+id/loginButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="10dp"
            >

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#E0E0E0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Or"
                android:textColor="@color/textPrimary"
                android:textSize="14sp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp" />
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#E0E0E0" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            app:layout_constraintTop_toBottomOf="@+id/extraOptions"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Google"
            app:icon="@drawable/ic_google"
            app:iconTint="@null"
            android:textColor="@color/textPrimary"
            android:textSize="14sp"
            android:paddingVertical="12dp"
            android:paddingHorizontal="38dp"
            android:backgroundTint="@color/primary"
            app:strokeColor="@color/lightGray"
            app:strokeWidth="1dp"
            app:rippleColor="@android:color/darker_gray"
            />
        <com.google.android.material.button.MaterialButton
            app:layout_constraintTop_toBottomOf="@+id/extraOptions"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Facebook"
            android:textColor="@color/textPrimary"
            app:iconTint="@null"
            app:icon="@drawable/ic_facebook"
            android:textSize="14sp"
            android:paddingVertical="12dp"
            android:paddingHorizontal="28dp"
            android:backgroundTint="@color/primary"
            app:strokeColor="@color/lightGray"
            app:strokeWidth="1dp"
            app:rippleColor="@android:color/darker_gray"
            />
    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>